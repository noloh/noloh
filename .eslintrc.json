{
  "env": {
    "browser": true
  },
  "parserOptions": {
    "ecmaVersion": 5
  },
  "globals": {
    "_N": "readonly",
    "_NSet": "readonly",
    "_NTimer": "writable",
    "AddScript": "readonly",
    "Priority": "readonly",
    "System": "readonly",
    "Configuration": "readonly",
    "NolohInternal": "readonly",
    "UserAgent": "readonly",
    "URL": "readonly"
  },
  "rules": {
    "no-undef": "error",
    "no-unused-vars": ["warn", { "vars": "local" }],
    "eqeqeq": ["warn", "always"]
  }
}
